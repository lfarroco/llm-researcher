DATABASE_URL=postgresql://postgres:postgres@db:5432/researcher
APP_ENV=development

# LLM Provider Configuration
# Options: "openai", "ollama"
LLM_PROVIDER=ollama

# Model name - depends on your provider
# For OpenAI: "gpt-4o", "gpt-4", "gpt-3.5-turbo", etc.
# For Ollama: "qwen3:4b", "llama2", "mistral", etc.
LLM_MODEL=qwen3:4b

# Temperature for LLM responses (0.0 - 1.0)
LLM_TEMPERATURE=0.2

# Ollama Configuration (only needed if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI Configuration (only needed if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Optional search provider keys
# SPRINGER_API_KEY enables Springer Nature metadata search plugin.
SPRINGER_API_KEY=
